{
  "name": "codegrunt",
  "version": "0.1.1",
  "description": "An AI-powered CLI coding assistant for the terminal — built on DeepSeek",
  "type": "module",
  "bin": {
    "codegrunt": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/cli/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "adm-zip": "^0.5.17",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "diff": "^9.0.0",
    "ignore": "^5.3.1",
    "ink": "^5.2.1",
    "openai": "^4.52.0",
    "ora": "^8.0.1",
    "react": "^18.3.0",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
